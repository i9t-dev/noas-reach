{
  "compilerOptions": {
    "target": "ES6",
    "module": "NodeNext",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext",
    "outDir": "./js/dist",
    "rootDir": "./js/src"
  },
  "include": ["js/src/**/*"]
}